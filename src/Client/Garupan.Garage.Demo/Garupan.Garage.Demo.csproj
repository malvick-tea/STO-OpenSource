<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Garupan.Garage.Demo</RootNamespace>
    <AssemblyName>Garupan.Garage.Demo</AssemblyName>
    <Description>Standalone Windows .exe that launches a live D3D12 window and renders the legacy sample vehicle through GarageSceneController. Proof of the full live-app rendering chain outside the test harness; foundation for the eventual Client.Windows boot pipeline migration.</Description>
